---
import ArchiveLayout from '../layouts/ArchiveLayout.astro';
import { projects } from '../data/projects';

// Helper to get all links for a project
const getProjectLinks = (project: any) => {
  const links = [];
  if (project.github) {
    links.push({ label: 'GitHub', url: project.github, type: 'github' });
  }
  if (project.external && project.external !== '#') {
    links.push({ label: 'Demo', url: project.external, type: 'external' });
  }
  if (project.links) {
    links.push(...project.links.map((l: any) => ({ ...l, type: 'other' })));
  }
  return links;
};
---

<ArchiveLayout title="Archive">
  <div class="table-container">
    <table class="archive-table">
      <thead>
        <tr>
          <th class="year-head">Year</th>
          <th class="title-head">Title</th>
          <th class="tech-head hide-on-mobile">Built with</th>
          <th class="links-head">Links</th>
        </tr>
      </thead>
      <tbody>
        {projects.map((project) => {
            const allLinks = getProjectLinks(project);
            return (
                <tr>
                  <td class="year">2024</td>
                  <td class="title">{project.title}</td>
                  <td class="tech hide-on-mobile">
                    <div class="tech-pills">
                        {project.tech.map((t) => (
                          <span class="pill">{t}</span>
                        ))}
                    </div>
                  </td>
                  <td class="links">
                    <div class="link-list">
                        {allLinks.map((link) => (
                          <a href={link.url} target="_blank" rel="noreferrer" class="text-link">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="mini-icon">
                                {link.type === 'github' ? (
                                    <path fill-rule="evenodd" d="M10 0C4.477 0 0 4.484 0 10.08c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0110 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0020 10.08C20 4.484 15.523 0 10 0z" clip-rule="evenodd" />
                                ) : link.type === 'external' ? (
                                    <path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 001.06 0l7.22-7.22v5.69a.75.75 0 001.5 0v-7.5a.75.75 0 00-.75-.75h-7.5a.75.75 0 000 1.5h5.69l-7.22 7.22a.75.75 0 000 1.06z" clip-rule="evenodd" />
                                ) : (
                                    <path fill-rule="evenodd" d="M15.621 4.379a3 3 0 00-4.242 0l-7 7a3 3 0 004.241 4.243h.001l.497-.5a.75.75 0 011.064 1.057l-.498.501-.002.002a4.5 4.5 0 01-6.364-6.364l7-7a4.5 4.5 0 016.368 6.36l-3.455 3.553A2.625 2.625 0 119.52 9.52l3.45-3.451a.75.75 0 111.061 1.06l-3.45 3.451a1.125 1.125 0 001.587 1.595l3.454-3.553a3 3 0 000-4.242z" clip-rule="evenodd" />
                                )}
                            </svg>
                            {link.label}
                          </a>
                        ))}
                    </div>
                  </td>
                </tr>
            );
        })}
      </tbody>
    </table>
  </div>
</ArchiveLayout>

<style>
  .table-container {
    overflow-x: auto;
    margin-left: -1rem;
    margin-right: -1rem;
    padding-left: 1rem;
    padding-right: 1rem;
  }
  
  .archive-table {
    width: 100%;
    border-collapse: collapse;
    border-spacing: 0;
  }

  /* Add background to rows to block grid */
  .archive-table tbody tr {
     background-color: var(--navy); /* Matches body background to mask grid */
     transition: background-color 0.2s;
  }

  .archive-table tbody tr:hover {
     background-color: var(--light-navy);
  }

  .archive-table th,
  .archive-table td {
    padding: 1rem;
    text-align: left;
    vertical-align: middle;
  }

  .archive-table th {
    color: var(--slate);
    font-size: 1rem;
    font-weight: 600;
  }

  .archive-table td {
    border-bottom: 1px solid var(--light-navy);
    color: var(--light-slate);
    font-size: 1rem;
  }

  .year {
    color: var(--green);
    font-family: var(--font-mono);
    font-size: 0.9rem !important;
    min-width: 60px;
  }

  .title {
    font-weight: 600;
    color: var(--lightest-slate) !important;
  }

  /* Tech Pills */
  .tech-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .pill {
    background-color: rgba(100, 255, 218, 0.1);
    color: var(--green);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    white-space: nowrap;
    transition: color 0.2s, background-color 0.2s;
  }

  /* Link Styling */
  .link-list {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
  }

  .text-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.85rem;
    font-family: var(--font-mono);
    color: var(--slate);
    text-decoration: none;
    transition: color 0.2s;
    white-space: nowrap;
  }

  .text-link:hover {
    color: var(--green);
  }
  
  .mini-icon {
    width: 1rem;
    height: 1rem;
  }

  @media (max-width: 768px) {
    .hide-on-mobile {
      display: none;
    }
  }
</style>
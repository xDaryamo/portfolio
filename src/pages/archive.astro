---
import ArchiveLayout from '../layouts/ArchiveLayout.astro';
import { projects } from '../data/projects';
import { Icon } from 'astro-icon/components';

// Helper to get all links for a project
const getProjectLinks = (project: any) => {
  const links = [];
  if (project.github) {
    links.push({ label: 'GitHub', url: project.github, type: 'github' });
  }
  if (project.external && project.external !== '#' && project.external !== project.github) {
    links.push({ label: 'Demo', url: project.external, type: 'external' });
  }
  if (project.links) {
    links.push(...project.links.map((l: any) => ({ ...l, type: 'other' })));
  }
  return links;
};
---

<ArchiveLayout title="Archive">
  <div class="table-container">
    <table class="archive-table">
      <thead>
        <tr>
          <th class="year-head">Year</th>
          <th class="title-head">Title</th>
          <th class="tech-head hide-on-mobile">Built with</th>
          <th class="links-head">Links</th>
        </tr>
      </thead>
      <tbody>
        {projects.map((project) => {
            const allLinks = getProjectLinks(project);
            return (
                <tr>
                  <td class="year">2024</td>
                  <td class="title">{project.title}</td>
                  <td class="tech hide-on-mobile">
                    <div class="tech-pills">
                        {project.tech.map((t) => (
                          <span class="pill">{t}</span>
                        ))}
                    </div>
                  </td>
                  <td class="links">
                    <div class="link-list">
                        {allLinks.map((link) => (
                          <a href={link.url} target="_blank" rel="noreferrer" class="text-link">
                            <Icon name={link.type === 'github' ? "mdi:github" : "heroicons:link-20-solid"} class="mini-icon" />
                            {link.label}
                          </a>
                        ))}
                    </div>
                  </td>
                </tr>
            );
        })}
      </tbody>
    </table>
  </div>
</ArchiveLayout>

<style>
  .table-container {
    overflow-x: auto;
    margin-left: -1rem;
    margin-right: -1rem;
    padding-left: 1rem;
    padding-right: 1rem;
  }
  
  .archive-table {
    width: 100%;
    border-collapse: collapse;
    border-spacing: 0;
  }

  /* Add background to rows to block grid */
  .archive-table tbody tr {
     background-color: var(--navy); /* Matches body background to mask grid */
     transition: background-color 0.2s;
  }

  .archive-table tbody tr:hover {
     background-color: var(--light-navy);
  }

  .archive-table th,
  .archive-table td {
    padding: 1rem;
    text-align: left;
    vertical-align: middle;
  }

  .archive-table th {
    color: var(--slate);
    font-size: 1rem;
    font-weight: 600;
  }

  .archive-table td {
    border-bottom: 1px solid var(--light-navy);
    color: var(--light-slate);
    font-size: 1rem;
  }

  .year {
    color: var(--green);
    font-family: var(--font-mono);
    font-size: 0.9rem !important;
    min-width: 60px;
  }

  .title {
    font-weight: 600;
    color: var(--lightest-slate) !important;
  }

  /* Tech Pills */
  .tech-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .pill {
    background-color: rgba(100, 255, 218, 0.1);
    color: var(--green);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    white-space: nowrap;
    transition: color 0.2s, background-color 0.2s;
  }

  /* Link Styling */
  .link-list {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
  }

  .text-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.85rem;
    font-family: var(--font-mono);
    color: var(--slate);
    text-decoration: none;
    transition: color 0.2s;
    white-space: nowrap;
  }

  .text-link:hover {
    color: var(--green);
  }
  
  .mini-icon {
    width: 1rem;
    height: 1rem;
  }

  @media (max-width: 768px) {
    .hide-on-mobile {
      display: none;
    }
  }
</style>
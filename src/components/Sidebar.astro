---
import { Image } from 'astro:assets';
import profilePhoto from '../assets/dario.png';
import GlareHover from './react/GlareHover';
---
<header class="sidebar">
  <div class="sidebar-content">
    <div class="identity">
      <div class="profile-photo-wrapper" id="profile-photo">
        <GlareHover
          width="100%"
          height="100%"
          borderRadius="24%"
          background="var(--light-navy)"
          borderColor="transparent"
          glareColor="#ffffff"
          glareOpacity={0.3}
          glareAngle={-30}
          glareSize={300}
          transitionDuration={800}
          playOnce={false}
        >
          <Image src={profilePhoto} alt="Dario Mazza" width={280} height={280} loading="eager" style={{ width: '100%', height: '100%', objectFit: 'cover', borderRadius: '24%' }} />
        </GlareHover>
      </div>
      <a href="/">
        <h1 class="name">Dario Mazza</h1>
      </a>
      <h2 class="title">Software Engineer</h2>
      <p class="tagline">I build accessible, pixel-perfect, performant, and reliable web experiences.</p>
    </div>

    <nav class="nav">
      <ul>
        <li><a href="#about" class="nav-link">About</a></li>
        <li><a href="#experience" class="nav-link">Experience</a></li>
        <li><a href="#projects" class="nav-link">Projects</a></li>
      </ul>
    </nav>

    <div class="socials">
      <a href="https://github.com" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
      </a>
      <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
      </a>
      <a href="mailto:email@example.com" aria-label="Email">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
      </a>
    </div>
  </div>
</header>

<script>
  const navLinks = document.querySelectorAll('.nav-link');
  const sections = document.querySelectorAll('section');

  const observerOptions = {
    root: null,
    rootMargin: '-20% 0px -70% 0px', // Focus on a narrow band near the top
    threshold: 0
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const id = entry.target.getAttribute('id');
        navLinks.forEach((link) => {
          link.classList.toggle('active', link.getAttribute('href') === `#${id}`);
        });
      }
    });
  }, observerOptions);

  sections.forEach((section) => observer.observe(section));

  // Fallback for top of page
  window.addEventListener('scroll', () => {
    if (window.scrollY < 100) {
      navLinks.forEach((link, i) => {
        link.classList.toggle('active', i === 0);
      });
    }
  }, { passive: true });
</script>

<style>
  .sidebar {
    position: relative;
    padding-top: 0;
  }

  .sidebar-content {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
    max-height: 100vh;
    padding: 5.5rem 0 3rem;
  }

  .profile-photo-wrapper {
    margin-bottom: 2rem;
    width: 250px;
    height: 250px;
    border-radius: 24%;
    overflow: hidden;
    border: 1px solid var(--lightest-navy);
    box-shadow: 0 10px 30px -15px rgba(2, 12, 27, 0.7);
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    background-color: var(--light-navy);
    cursor: default;
  }

  /* Target the Image inside the React component if needed, or rely on inline style passed to Image */
  /* .profile-photo img styles removed as they are now inline or managed by GlareHover/Image props */


  .identity .name {
    font-size: 3rem;
    font-weight: 700;
    color: var(--lightest-slate);
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }

  .identity .title {
    font-size: 1.25rem;
    color: var(--lightest-slate);
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .identity .tagline {
    max-width: 300px;
    color: var(--slate);
    line-height: 1.5;
  }

  .nav ul {
    list-style: none;
    padding: 0;
    margin: 2rem 0;
  }

  .nav-link {
    display: flex;
    align-items: center;
    padding: 0.75rem 0;
    color: var(--slate);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    transition: all 0.3s ease;
  }

  .nav-link:hover, .nav-link.active {
    color: var(--lightest-slate);
  }

  .nav-link:hover::before, .nav-link.active::before {
    width: 3rem;
    background-color: var(--lightest-slate);
  }

  .nav-link::before {
    content: '';
    display: inline-block;
    width: 1rem;
    height: 1px;
    background-color: var(--slate);
    margin-right: 1rem;
    transition: all 0.3s ease;
  }

  .socials {
    display: flex;
    gap: 1.5rem;
    margin-top: auto;
  }

  .socials a {
    color: var(--slate);
    transition: color 0.3s ease;
  }

  .socials a:hover {
    color: var(--lightest-slate);
  }

  /* Desktop Styles (Sidebar becomes sticky) */
  @media (min-width: 1024px) {
    .sidebar {
      position: sticky;
      top: 0;
      height: 100vh;
      width: 30%;
      padding: 0 2rem;
    }
  }

  /* Mobile Styles */
  @media (max-width: 1023px) {
    .sidebar {
      width: 100%;
      height: auto;
      padding: 5rem 1.5rem 3rem;
    }
    
    .sidebar-content {
      padding: 0;
      gap: 2rem;
    }
    
    .nav {
      display: none; /* Often hidden on mobile or turned into a hamburger */
    }
  }
</style>
